{
  "expo": {
    "name": "Bhagavad Gita",
    "slug": "gita-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": ["android"],
    "android": {
      "package": "com.nielless.gita",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#FAFAF7"
      }
    },
    "plugins": [
      [
        "expo-sqlite",
        {
          "enableFTS": true
        }
      ]
    ],
    "assetBundlePatterns": ["assets/**/*"]
  }
}